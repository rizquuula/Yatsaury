# Yatsaury environment variables — copy to .env and fill in values

# LLM provider
YATSAURY_API_KEY=sk-your-api-key-here
YATSAURY_BASE_URL=https://api.openai.com/v1
YATSAURY_MODEL=gpt-4o-mini
YATSAURY_JUDGE_MODEL=

# Generation settings
YATSAURY_CHUNK_SIZE=512
YATSAURY_CHUNK_OVERLAP=64
YATSAURY_PER_CHUNK=3
YATSAURY_MIN_SCORE=0.7
YATSAURY_LANG=auto

# Web UI & workspace
YATSAURY_WORKSPACE=./.yatsaury
YATSAURY_WEB_HOST=127.0.0.1
YATSAURY_WEB_PORT=8080

# Alternatively, standard OpenAI env vars are accepted as fallbacks:
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
